{
  "name": "warframe-weekly-rivens",
  "type": "module",
  "version": "0.0.3",
  "description": "A lightweight client for accessing Warframe weekly Riven history hosted on Cloudflare Pages.",
  "author": "CloudeaSoft <cloudeasoft@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/CloudeaSoft/warframe-weekly-rivens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudeaSoft/warframe-weekly-rivens.git"
  },
  "bugs": {
    "url": "https://github.com/CloudeaSoft/warframe-weekly-rivens/issues"
  },
  "keywords": [
    "warframe",
    "riven"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "lib"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "lint": "eslint",
    "publish": "pnpm lint && pnpm build && pnpm test:coverage && pnpm typecheck && pnpm publish",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@eslint/json": "^2.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
